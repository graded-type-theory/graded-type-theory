    open Modality linear-or-affine
      hiding (рЭЯШ; рЭЯЩ; _+_; _¬Ј_; _вИІ_; _вЙ§_)

    nrвВВ : OpвВВ Linear-or-affine
    nrвВВ p r = рЭЯЩ вИІ (r + p)

