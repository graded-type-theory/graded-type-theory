  linear-or-affine-has-factoring-nr = record
    { nrвВВ = nrвВВ
    ; nrвВВвЙҐрЭЯШ = ќї {p} {r} вЖТ рЭЯЩвИІpвЙҐрЭЯШ (r + p)
