        , О» { рқҹҳ qвүӨ вҶ’ вҠҘ-elim (lemmaвҖІ (pбөў 0) _ (О» ()) (qвүӨ 0))
            ; рқҹҷ qвүӨ вҶ’ вҠҘ-elim (lemmaвҖІ (pбөў 0) _ (О» ()) (qвүӨ 0))
            ; вүӨрқҹҷ qвүӨ вҶ’ вҠҘ-elim (lemmaвҖІ (pбөў 0) _ (О» ()) (qвүӨ 0))
            ; вүӨПү qвүӨ вҶ’ refl}

    open Tools.Reasoning.PartialOrder вүӨ-poset

    +nrбөў-GLB :
      вҲҖ {pвӮҒ pвӮӮ} вҶ’
      Greatest-lower-bound pвӮҒ (nrбөў r zвӮҒ sвӮҒ) вҶ’
      Greatest-lower-bound pвӮӮ (nrбөў r zвӮӮ sвӮӮ) вҶ’
      вҲғ О» q вҶ’ Greatest-lower-bound q (nrбөў r (zвӮҒ + zвӮӮ) (sвӮҒ + sвӮӮ)) Г—
          pвӮҒ + pвӮӮ вүӨ q
    +nrбөў-GLB {r} {zвӮҒ} {sвӮҒ} {zвӮӮ} {sвӮӮ} {pвӮҒ} {pвӮӮ} pвӮҒ-glb pвӮӮ-glb =
      _ , nr-nrбөў-GLB r , (begin
        pвӮҒ + pвӮӮ                         вүЎвҹЁ +-cong (GLB-unique pвӮҒ-glb (nr-nrбөў-GLB r))
                                           (GLB-unique pвӮӮ-glb (nr-nrбөў-GLB r)) вҹ©
        nr рқҹҳ r zвӮҒ sвӮҒ рқҹҳ + nr рқҹҳ r zвӮӮ sвӮӮ рқҹҳ вүӨвҹЁ Has-nr.nr-+ linear-or-affine-has-nr {рқҹҳ} {r} вҹ©
        nr рқҹҳ r (zвӮҒ + zвӮӮ) (sвӮҒ + sвӮӮ) рқҹҳ    вҲҺ)

opaque

  -- The greatest lower bound for certain nrбөў sequences

  nrбөў-рқҹҳ-GLB :
    let рқ•„ = linear-or-affine-semiring-with-meet in
    вҲҖ p q вҶ’ Semiring-with-meet.Greatest-lower-bound
            рқ•„ (p вҲ§ q) (Semiring-with-meet.nrбөў рқ•„ рқҹҳ p q)
  nrбөў-рқҹҳ-GLB p q = Natrec.nrбөў-рқҹҳ-GLB linear-or-affine-semiring-with-meet

opaque

  -- The greatest lower bound of certain nrбөў sequences

  nrбөў-рқҹҷ-GLB :
    let рқ•„ = linear-or-affine-semiring-with-meet in
    вҲҖ p q вҶ’ Semiring-with-meet.Greatest-lower-bound
            рқ•„ (p + вүӨПү В· q) (Semiring-with-meet.nrбөў рқ•„ рқҹҷ p q)
  nrбөў-рқҹҷ-GLB p q =
    GLB.GLB-congКі linear-or-affine-semiring-with-meet
      (Semiring-with-meet.+-comm linear-or-affine-semiring-with-meet (вүӨПү В· q) p)
      (nr-nrбөў-GLB {z = p} {s = q} рқҹҷ)

opaque

  -- The greatest lower bound for certain nrбөў sequences

  nrбөў-вүӨПү-GLB :
    let рқ•„ = linear-or-affine-semiring-with-meet in
    вҲҖ p q вҶ’ Semiring-with-meet.Greatest-lower-bound
            рқ•„ (вүӨПү В· (p + q)) (Semiring-with-meet.nrбөў рқ•„ вүӨПү p q)
  nrбөў-вүӨПү-GLB p q =
    GLB.GLB-congКі linear-or-affine-semiring-with-meet
      (В·-congЛЎ {x = вүӨПү} (+-comm q p))
      (nr-nrбөў-GLB {z = p} {s = q} вүӨПү)
      where
      open Semiring-with-meet linear-or-affine-semiring-with-meet
        hiding (_В·_; _+_)
