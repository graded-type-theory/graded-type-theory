module _ {рқҹҳбөҗ-allowed : Bool} where

  open Graded.Mode.Instances.Zero-one.Variant linear-or-affine

  private
    variant : Mode-variant
    variant = record
      { рқҹҳбөҗ-allowed = рқҹҳбөҗ-allowed
      ; рқҹҳ-well-behaved = О» _ вҶ’ linear-or-affine-has-well-behaved-zero
      }

  open Graded.Mode.Instances.Zero-one variant
  open Graded.Usage.Restrictions linear-or-affine Zero-one-isMode
  open Graded.FullReduction.Assumptions variant
  open Definition.Typed.Restrictions linear-or-affine

  private variable
    trs     : Type-restrictions
    urs     : Usage-restrictions

  -- Instances of Type-restrictions and Usage-restrictions are suitable
  -- for the full reduction theorem if
  -- * whenever UnitЛў-allowed holds, then StarЛў-sink holds,
  -- * UnitК·-allowed and UnitК·-О· do not both hold,
  -- * ОЈЛў-allowedВ рқҹҳВ p does not hold,
  -- * ОЈЛў-allowedВ вүӨрқҹҷВ p does not hold, and
  -- * ОЈЛў-allowedВ вүӨПүВ p does not hold.

  Suitable-for-full-reduction :
    Type-restrictions вҶ’
    Usage-restrictions вҶ’
