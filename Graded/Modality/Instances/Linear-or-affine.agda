        , О» { рқҹҳ qвүӨ вҶ’ вҠҘ-elim (вүўp-GLB-inv (О» ()) p-glb (lemmaвҖІ _ _ (О» ()) вҲҳвҶ’ qвүӨ))
            ; рқҹҷ qвүӨ вҶ’ вҠҘ-elim (вүўp-GLB-inv (О» ()) p-glb (lemmaвҖІ _ _ (О» ()) вҲҳвҶ’ qвүӨ))
            ; вүӨрқҹҷ qвүӨ вҶ’ вҠҘ-elim (вүўp-GLB-inv (О» ()) p-glb (lemmaвҖІ _ _ (О» ()) вҲҳвҶ’ qвүӨ))
            ; вүӨПү qвүӨ вҶ’ refl}
      lemma вүӨПү p-glb =
          (О» _ вҶ’ refl)
        , О» { рқҹҳ qвүӨ вҶ’ вҠҘ-elim (вүўp-GLB-inv (О» ()) p-glb (lemmaвҖІ _ _ (О» ()) вҲҳвҶ’ qвүӨ))
            ; рқҹҷ qвүӨ вҶ’ вҠҘ-elim (вүўp-GLB-inv (О» ()) p-glb (lemmaвҖІ _ _ (О» ()) вҲҳвҶ’ qвүӨ))
            ; вүӨрқҹҷ qвүӨ вҶ’ вҠҘ-elim (вүўp-GLB-inv (О» ()) p-glb (lemmaвҖІ _ _ (О» ()) вҲҳвҶ’ qвүӨ))
            ; вүӨПү qвүӨ вҶ’ refl}
    +-GLBЛЎ {q = вүӨПү} {pбөў} p-glb = lemma _ p-glb
      where
      lemmaвҖІ : вҲҖ p q вҶ’ q вүў вүӨПү вҶ’ q вүӨ вүӨПү + p вҶ’ вҠҘ
      lemmaвҖІ p рқҹҳ qвүўПү x rewrite вүӨПү+ p = case x of О» ()
      lemmaвҖІ p рқҹҷ qвүўПү x rewrite вүӨПү+ p = case x of О» ()
      lemmaвҖІ p вүӨрқҹҷ qвүўПү x rewrite вүӨПү+ p = case x of О» ()
      lemmaвҖІ p вүӨПү qвүўПү _ = qвүўПү refl
      lemma :
        вҲҖ p вҶ’ Greatest-lower-bound p pбөў вҶ’
        Greatest-lower-bound (вүӨПү + p) (О» i вҶ’ вүӨПү + pбөў i)
      lemma рқҹҳ p-glb =
        GLB-const (О» i вҶ’ +-congЛЎ {x = вүӨПү} (рқҹҳ-GLB-inv p-glb i))
      lemma рқҹҷ p-glb =
          (О» _ вҶ’ refl)
        , О» { рқҹҳ qвүӨ вҶ’ вҠҘ-elim (lemmaвҖІ (pбөў 0) _ (О» ()) (qвүӨ 0))
            ; рқҹҷ qвүӨ вҶ’ вҠҘ-elim (lemmaвҖІ (pбөў 0) _ (О» ()) (qвүӨ 0))
            ; вүӨрқҹҷ qвүӨ вҶ’ вҠҘ-elim (lemmaвҖІ (pбөў 0) _ (О» ()) (qвүӨ 0))
            ; вүӨПү qвүӨ вҶ’ refl}
      lemma вүӨрқҹҷ p-glb =
          (О» _ вҶ’ refl)
        , О» { рқҹҳ qвүӨ вҶ’ вҠҘ-elim (lemmaвҖІ (pбөў 0) _ (О» ()) (qвүӨ 0))
            ; рқҹҷ qвүӨ вҶ’ вҠҘ-elim (lemmaвҖІ (pбөў 0) _ (О» ()) (qвүӨ 0))
            ; вүӨрқҹҷ qвүӨ вҶ’ вҠҘ-elim (lemmaвҖІ (pбөў 0) _ (О» ()) (qвүӨ 0))
            ; вүӨПү qвүӨ вҶ’ refl}
      lemma вүӨПү p-glb =
